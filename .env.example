# ==================================================================
# 企业级财务智能体 - MVP 环境变量示例
# 复制本文件为 .env 后按需修改。
#
# 设计原则：
#   - 默认与 Dify（开源流程编排）一起启动，开箱即用
#   - 执行 `make init && make up` 即可启动完整系统
#   - Redis / MinIO / Celery 作为可选扩展保留，需要时再启用
#   - 不启动 Dify 时，使用 `make up-core`（需加 --profile local-db 启动数据库）
# ==================================================================

# ------------------------------------------------------------------
# Docker Compose 项目配置
# ------------------------------------------------------------------
COMPOSE_PROJECT_NAME=financial-agent

# ------------------------------------------------------------------
# Dify 核心配置（覆盖官方默认值）
# ------------------------------------------------------------------
# 本地访问端口，避免 80 端口权限问题
EXPOSE_NGINX_PORT=8080
NGINX_PORT=80

# 数据库与向量库类型
VECTOR_STORE=weaviate
DB_TYPE=postgresql

# 关闭 Dify 协作模式的独立 websocket 服务，降低资源占用
# MVP 阶段不需要实时协作功能
COMPOSE_PROFILES=weaviate,postgresql

# 启动时执行数据库迁移
MIGRATION_ENABLED=true

# Dify 控制台与应用的访问地址（本地开发）
CONSOLE_API_URL=http://localhost:5001
CONSOLE_WEB_URL=http://localhost:3000
APP_API_URL=http://localhost:5001
APP_WEB_URL=http://localhost:3000

# 安全密钥：生产环境必须修改为随机长字符串（≥32 字符）
SECRET_KEY=change-me-in-production-32-char-min

# 首次登录管理员密码（生产环境必须修改为强密码，切勿使用示例值）
INIT_PASSWORD=change-me-to-a-strong-password

# 数据库与缓存（与 docker-compose 中 Dify 默认服务一致即可）
DB_USERNAME=postgres
DB_PASSWORD=difyai123456
DB_HOST=db_postgres
DB_PORT=5432
DB_DATABASE=dify

# ------------------------------------------------------------------
# 存储后端配置（默认本地文件系统，无需 MinIO）
# ------------------------------------------------------------------
# local: 本地文件系统存储（默认），文件映射到命名卷 backend_storage
# minio: MinIO 对象存储（需 docker compose --profile minio 启动）
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=/app/data/storage

# 仅 STORAGE_BACKEND=minio 时启用并配置以下参数
# MINIO_ENDPOINT=fa-minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin123
# MINIO_BUCKET=financial-agent
# MINIO_PUBLIC_URL=http://localhost:9000
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin123

# ------------------------------------------------------------------
# 任务执行后端配置（默认本地同步，无需 Redis）
# ------------------------------------------------------------------
# sync  : 本地同步执行（默认），任务在请求进程内执行，无外部依赖
# celery: 异步执行，需 Redis 作为 broker（docker compose --profile celery 启动）
TASK_BACKEND=sync

# 仅 TASK_BACKEND=celery 时需要配置 Redis
# REDIS_PASSWORD=difyai123456
# REDIS_URL=redis://:difyai123456@redis:6379/2
# CELERY_BROKER_URL=redis://:difyai123456@redis:6379/2
# CELERY_RESULT_BACKEND=redis://:difyai123456@redis:6379/2

# ------------------------------------------------------------------
# Ollama 本地模型配置
# ------------------------------------------------------------------
# 默认使用 Qwen2.5 7B（Ollama 官方 tag 已默认 4-bit 量化）
# 若硬件资源紧张，可改为 qwen2.5:3b 或 qwen2.5:1.5b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=http://fa-ollama:11434

# ------------------------------------------------------------------
# Dify 流程编排对接（可选）
# ------------------------------------------------------------------
# Dify API 基础地址，通常为 http://localhost:5001/v1
DIFY_BASE_URL=http://localhost:5001/v1
# Dify Workflow/API 密钥，用于后端调用 Dify
DIFY_API_KEY=your-dify-api-key
# Dify Workflow ID，用于后端默认调用的工作流
DIFY_WORKFLOW_ID=your-dify-workflow-id
# Dify 调用后端 Tools 时使用的 API Key，需在 Dify HTTP Request 节点 Header 中配置 X-API-Key
DIFY_TOOL_API_KEY=financial-agent-dify-tools-secret-key

# ------------------------------------------------------------------
# IM 机器人（可选）
# ------------------------------------------------------------------
# 钉钉机器人加签密钥（机器人设置页面获取）
DINGTALK_APP_SECRET=your-dingtalk-app-secret
# 钉钉机器人 Webhook 地址（用于主动推送审批通知）
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# 飞书事件订阅 Encrypt Key（事件订阅页面获取）
FEISHU_ENCRYPT_KEY=your-feishu-encrypt-key
# 飞书机器人 Webhook 地址（用于主动推送审批通知）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# 企业微信回调 Token（应用管理后台获取）
WECOM_TOKEN=your-wecom-token
# 企业微信回调 EncodingAESKey（应用管理后台获取，43 位字符）
WECOM_ENCODING_AES_KEY=your-wecom-encoding-aes-key
# 企业微信机器人 Webhook 地址（用于主动推送审批通知）
WECOM_WEBHOOK=https://qyapi.weixi.qq.com/cgi-bin/webhook/send?key=xxx

# ------------------------------------------------------------------
# 后端服务配置
# ------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
# MVP 阶段复用 Dify 的 Postgres 数据库（dify），避免额外初始化。
# 生产环境应为后端单独创建数据库 financial_agent。
DATABASE_URL=postgresql+psycopg://postgres:difyai123456@db_postgres:5432/dify

# Text2SQL 后端选择：rule（默认）/ vanna（需安装 .[ai] 并配置 Ollama）
TEXT2SQL_BACKEND=rule

# Agent 意图识别与 RAG
AGENT_INTENT_MODE=llm
AGENT_LLM_MODEL=qwen2.5:7b
RAG_CHUNK_SIZE=512
RAG_TOP_K=3

# PDF 解析增强（可选）
# 配置 Mineru HTTP 地址后优先使用 Mineru，否则使用内置 pdfplumber
MINERU_API_URL=
MINERU_TIMEOUT=120

# 生产加固
# CORS 允许的源，多个用逗号分隔；生产环境必须限制为前端域名
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# 请求速率限制（单实例内存实现，多实例需使用网关层限流）
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
