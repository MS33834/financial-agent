{
  "info": {
    "name": "Financial Agent MVP API",
    "description": "企业级财务智能体 MVP 后端 API 测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"demo_admin\", \"password\": \"demo123\"}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "Queries",
      "item": [
        {
          "name": "NL2SQL Query",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "url": "{{base_url}}/api/v1/queries/nl2sql",
            "body": {
              "mode": "raw",
              "raw": "{\"question\": \"2025 年 Q2 净利润是多少\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Agent",
      "item": [
        {
          "name": "Agent Chat",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "url": "{{base_url}}/api/v1/agent/chat",
            "body": {
              "mode": "raw",
              "raw": "{\"question\": \"2025 年 Q2 净利润是多少\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Create Report",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "url": "{{base_url}}/api/v1/reports",
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"2025 Q2 利润表\", \"report_type\": \"profit\", \"parameters\": {\"year\": 2025, \"period\": \"Q2\"}}"
            }
          }
        },
        {
          "name": "List Reports",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/reports"
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/documents/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file", "type": "file", "src": "/path/to/demo.pdf"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Approvals",
      "item": [
        {
          "name": "Approve Report",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "url": "{{base_url}}/api/v1/approvals/{{report_id}}/action",
            "body": {
              "mode": "raw",
              "raw": "{\"action\": \"approve\", \"comments\": \"审核通过\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Audit",
      "item": [
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": "{{base_url}}/api/v1/audit/logs"
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "base_url", "value": "http://localhost:3000"},
    {"key": "access_token", "value": ""}
  ]
}
