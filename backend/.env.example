# ============================================================================
# Financial Agent 后端配置示例
# ============================================================================
# 复制为 .env 并按需修改。
#
# 设计原则：默认全部本地化，无需部署任何外部服务（Redis / MinIO）。
# MinIO 对象存储与 Celery 异步任务作为可选扩展，按需开启。
# ============================================================================

# ---- 应用基础 ----
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
# JWT / 加密密钥，生产环境务必替换为随机长字符串（>=32 字符）
SECRET_KEY=change-me-to-a-random-secret-key

# ---- 数据库 ----
# 默认 SQLite，开箱即用；生产环境建议 PostgreSQL
DATABASE_URL=sqlite:///./data/financial_agent.db
DATABASE_ECHO=false

# ---- 任务执行后端（默认本地同步，无需 Redis）----
# sync  : 本地同步执行（默认），任务在请求进程内执行，无外部依赖
# celery: 异步执行，需要 Redis 作为 broker，适合生产环境高并发
TASK_BACKEND=sync
# 仅 TASK_BACKEND=celery 时需要配置 Redis
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ---- 对象存储（默认本地文件系统，无需 MinIO）----
# local: 本地文件系统存储（默认），文件保存在 STORAGE_LOCAL_ROOT 目录
# minio: MinIO 对象存储，适合分布式部署
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./data/storage
# 仅 STORAGE_BACKEND=minio 时需要配置以下 MinIO 参数
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=financial-agent
MINIO_PUBLIC_URL=

# ---- LLM / AI ----
# ollama: 本地 Ollama 服务（默认）
# openai: OpenAI 兼容 API
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# OpenAI 兼容 API（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ---- Dify 流程编排（可选扩展）----
DIFY_BASE_URL=
DIFY_API_KEY=
DIFY_WORKFLOW_ID=
DIFY_TOOL_API_KEY=

# ---- Text2SQL ----
TEXT2SQL_BACKEND=rule

# ---- Agent ----
AGENT_INTENT_MODE=rule
AGENT_LLM_MODEL=qwen2.5:7b
RAG_CHUNK_SIZE=512
RAG_TOP_K=3

# ---- IM 机器人（可选，按需配置）----
DINGTALK_APP_SECRET=
DINGTALK_WEBHOOK=
FEISHU_ENCRYPT_KEY=
FEISHU_WEBHOOK=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_WEBHOOK=

# ---- Mineru / Magic-PDF 解析服务（可选扩展）----
# 配置后 PDF 解析将调用外部 Mineru 服务，未配置时使用内置 pdfplumber 解析
MINERU_API_URL=
MINERU_TIMEOUT=120

# ---- 业务 ----
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ---- 生产加固 ----
# CORS 允许的源，生产环境应限制为前端域名（逗号分隔）
CORS_ORIGINS=*
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# ---- 初始化管理员密码（可选）----
# 未设置时首次启动会自动生成随机密码并打印到日志
INIT_PASSWORD=
